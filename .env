# .env
# ============================================
# VARIÁVEIS DE AMBIENTE
# ============================================
# ⚠️ ESTE ARQUIVO CONTÉM DADOS SENSÍVEIS
# ⚠️ NUNCA COMPARTILHE OU FAÇA COMMIT NO GIT

# ============================================
# SEGURANÇA
# ============================================

# Chave secreta para gerar tokens JWT
# ⚠️ MUDE ISTO ANTES DE USAR EM PRODUÇÃO!
# Você pode gerar uma chave aleatória aqui: https://randomkeygen.com/
SECRET_KEY=sua-chave-super-secreta-mude-isto-em-producao-12345

# ============================================
# BANCO DE DADOS
# ============================================

# URL do banco de dados
DATABASE_URL=sqlite:///./sistema_chamados.db

# ============================================
# MODO DEBUG
# ============================================

# True = Modo desenvolvimento (recarrega automaticamente)
# False = Modo produção
DEBUG=True

# ============================================
# EMAIL (para futuro)
# ============================================

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=seu-email@gmail.com
SENDER_PASSWORD=sua-senha-aqui